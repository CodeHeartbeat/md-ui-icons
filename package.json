{
  "name": "@md-ui/icons",
  "version": "1.0.0",
  "description": "Vue components of md-ui Icons collection.",
  "author": "",
  "keywords": [
    "icon",
    "svg",
    "vue",
    "md-ui"
  ],
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/umd/md-ui-icons.umd.cjs",
  "module": "./dist/es/md-ui-icons.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/umd/md-ui-icons.umd.cjs",
      "import": "./dist/es/md-ui-icons.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "scripts": {
    "gen": "tsx ./src/script/generate.ts",
    "build": "npm run gen && npm run build-only && npm run build:types",
    "build-only": "run-p build-es build-umd",
    "build-umd": "vite build --config vite.umd.config.ts",
    "build-es": "vite build --config vite.es.config.ts",
    "build:types": "vue-tsc --declaration --emitDeclarationOnly",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:eslint": "eslint . --fix --cache",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "vue": "^3.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.1",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.7.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "~6.0.0",
    "vite": "^8.0.8",
    "vue": "^3.5.32",
    "vue-tsc": "^3.2.6"
  },
  "license": "MIT"
}
